{
  "name": "@nordlig/tokens",
  "version": "1.0.0",
  "description": "Nordlig Design System - Design Tokens (4-Layer Architecture)",
  "main": "dist/tokens.js",
  "types": "dist/tokens.d.ts",
  "exports": {
    ".": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    },
    "./json": "./dist/tokens.json"
  },
  "sideEffects": false,
  "files": [
    "dist/**",
    "src/**"
  ],
  "scripts": {
    "build": "style-dictionary build --config style-dictionary.config.js",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "style-dictionary": "^5.4.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NCS23/nordlig-design-system.git",
    "directory": "packages/tokens"
  },
  "keywords": [
    "design-tokens",
    "nordlig",
    "design-system",
    "css-variables"
  ]
}
