{
  "font": {
    "base": {
      "$description": "Level 1: Base typography tokens",
      "family": {
        "sans":  { "$type": "fontFamily", "$value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" },
        "serif": { "$type": "fontFamily", "$value": "'Merriweather', Georgia, serif" },
        "mono":  { "$type": "fontFamily", "$value": "'DM Mono', 'JetBrains Mono', 'Fira Code', monospace" }
      },
      "size": {
        "xs":   { "$type": "dimension", "$value": "0.75rem" },
        "sm":   { "$type": "dimension", "$value": "0.875rem" },
        "base": { "$type": "dimension", "$value": "1rem" },
        "lg":   { "$type": "dimension", "$value": "1.125rem" },
        "xl":   { "$type": "dimension", "$value": "1.25rem" },
        "2xl":  { "$type": "dimension", "$value": "1.5rem" },
        "3xl":  { "$type": "dimension", "$value": "1.875rem" },
        "4xl":  { "$type": "dimension", "$value": "2.25rem" },
        "5xl":  { "$type": "dimension", "$value": "3rem" }
      },
      "weight": {
        "light":    { "$type": "fontWeight", "$value": 300 },
        "normal":   { "$type": "fontWeight", "$value": 400 },
        "medium":   { "$type": "fontWeight", "$value": 500 },
        "semibold": { "$type": "fontWeight", "$value": 600 },
        "bold":     { "$type": "fontWeight", "$value": 700 }
      },
      "lineHeight": {
        "$description": "Fixed pixel line-heights per font-size tier (font-size × 1.5 ratio, rounded)",
        "xs":   { "$type": "dimension", "$value": "18px" },
        "sm":   { "$type": "dimension", "$value": "21px" },
        "base": { "$type": "dimension", "$value": "24px" },
        "lg":   { "$type": "dimension", "$value": "27px" },
        "xl":   { "$type": "dimension", "$value": "30px" },
        "2xl":  { "$type": "dimension", "$value": "36px" },
        "3xl":  { "$type": "dimension", "$value": "45px" },
        "4xl":  { "$type": "dimension", "$value": "54px" },
        "5xl":  { "$type": "dimension", "$value": "72px" }
      },
      "letterSpacing": {
        "tight":  { "$type": "dimension", "$value": "-0.025em" },
        "normal": { "$type": "dimension", "$value": "0em" },
        "wide":   { "$type": "dimension", "$value": "0.025em" }
      }
    }
  }
}
