{
  "color": {
    "$description": "Level 4: PasswordInput component tokens",
    "pwinput": {
      "toggle":          { "$type": "color", "$value": "{color.text.muted}",   "$description": "Toggle icon color" },
      "toggle-hover":    { "$type": "color", "$value": "{color.text.base}",    "$description": "Toggle icon hover" },
      "strength-weak":   { "$type": "color", "$value": "{color.text.error}",   "$description": "Strength: weak" },
      "strength-medium": { "$type": "color", "$value": "{color.text.warning}", "$description": "Strength: medium" },
      "strength-strong": { "$type": "color", "$value": "{color.text.success}", "$description": "Strength: strong" }
    }
  }
}
