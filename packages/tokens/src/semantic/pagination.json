{
  "color": {
    "$description": "Level 4: Pagination component tokens",
    "pagination": {
      "item": {
        "bg":            { "$type": "color", "$value": "{color.bg.paper}", "$description": "Page button background" },
        "border":        { "$type": "color", "$value": "{color.border.default}", "$description": "Page button border" },
        "text":          { "$type": "color", "$value": "{color.text.base}", "$description": "Page button text" },
        "hover-bg":      { "$type": "color", "$value": "{color.bg.surface}", "$description": "Page button hover background" },
        "active-bg":     { "$type": "color", "$value": "{color.bg.primary}", "$description": "Active page background (Sky Blue)" },
        "active-text":   { "$type": "color", "$value": "{color.text.on-primary}", "$description": "Active page text (white)" },
        "active-border": { "$type": "color", "$value": "{color.bg.primary}", "$description": "Active page border (Sky Blue)" }
      }
    }
  },
  "font": {
    "pagination": {
      "item-weight":  { "$type": "dimension", "$value": "{font.component.weight.medium}", "$description": "Page button font weight" },
      "info-size":    { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Compact variant info text font size" }
    }
  },
  "sizing": {
    "$description": "Level 4: Pagination size tokens — References Level 3 only",
    "pagination": {
      "item-size": { "$type": "dimension", "$value": "{sizing.component.height.sm}", "$description": "Page button width & height (36px square)" },
      "font-size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Page button font size" }
    }
  },
  "radius": {
    "pagination": {
      "item": { "$type": "dimension", "$value": "{radius.component.md}", "$description": "6px rounded corners" }
    }
  },
  "spacing": {
    "pagination": {
      "nav-gap":  { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between pagination nav elements (8px)" },
      "item-gap": { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Gap between page buttons (4px)" }
    }
  }
}
