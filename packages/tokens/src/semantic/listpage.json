{
  "spacing": {
    "$description": "Level 4: ListPage template tokens",
    "listpage": {
      "header-gap":  { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap between title and action button (8px)" },
      "toolbar-gap": { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between toolbar items (8px)" },
      "section-gap": { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Gap between page sections (16px)" },
      "footer-gap":  { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap in footer area (8px)" }
    }
  }
}
