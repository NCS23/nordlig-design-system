{
  "color": {
    "$description": "Level 4: Sheet component tokens",
    "sheet": {
      "overlay":     { "$type": "color", "$value": "{color.bg.overlay}", "$description": "Sheet backdrop overlay" },
      "bg":          { "$type": "color", "$value": "{color.bg.paper}", "$description": "Sheet panel background" },
      "border":      { "$type": "color", "$value": "{color.border.muted}", "$description": "Sheet border" },
      "title":       { "$type": "color", "$value": "{color.text.base}", "$description": "Sheet title text" },
      "description": { "$type": "color", "$value": "{color.text.muted}", "$description": "Sheet description text" }
    }
  },
  "shadow": {
    "sheet": { "$type": "shadow", "$value": "{shadow.elevation.floating}", "$description": "Sheet panel shadow" }
  },
  "spacing": {
    "sheet": {
      "padding":    { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "Sheet content padding" },
      "header-gap": { "$type": "dimension", "$value": "{sizing.component.gap.sm}", "$description": "Gap between title and description in header (6px)" },
      "footer-gap": { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between footer buttons (8px)" },
      "close-inset":  { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px close button offset from edge" },
      "header-mb":    { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px header bottom margin" },
      "footer-pt":    { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px footer top padding" }
    }
  },
  "sizing": {
    "sheet": {
      "close-size": { "$type": "dimension", "$value": "{sizing.component.icon.lg}", "$description": "32px close button width/height" }
    }
  },
  "font": {
    "sheet": {
      "title-size":       { "$type": "dimension", "$value": "{font.component.size.lg}", "$description": "Sheet title font size (text-lg equivalent)" },
      "title-weight":     { "$type": "fontWeight", "$value": "{font.component.weight.semibold}", "$description": "Sheet title font weight (font-semibold)" },
      "description-size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Sheet description font size (text-sm equivalent)" }
    }
  }
}
