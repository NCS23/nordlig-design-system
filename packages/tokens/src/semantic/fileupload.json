{
  "color": {
    "$description": "Level 4: FileUpload component tokens",
    "fileupload": {
      "zone-bg":          { "$type": "color", "$value": "{color.bg.surface}", "$description": "Upload zone background" },
      "zone-border":      { "$type": "color", "$value": "{color.border.default}", "$description": "Dashed border" },
      "zone-text":        { "$type": "color", "$value": "{color.text.base}", "$description": "Zone primary instruction text" },
      "zone-text-sub":    { "$type": "color", "$value": "{color.text.muted}", "$description": "Zone secondary/sub text" },
      "zone-icon":        { "$type": "color", "$value": "{color.interactive.primary}", "$description": "Upload cloud icon" },
      "hover-bg":         { "$type": "color", "$value": "{color.bg.primary-subtle}", "$description": "Hover bg" },
      "hover-border":     { "$type": "color", "$value": "{color.border.focus}", "$description": "Hover border" },
      "drag-bg":          { "$type": "color", "$value": "{color.bg.primary-subtle}", "$description": "Drag-over bg" },
      "drag-border":      { "$type": "color", "$value": "{color.border.focus}", "$description": "Drag-over border" },
      "drag-icon":        { "$type": "color", "$value": "{color.bg.primary}", "$description": "Drag-over icon" },
      "drag-text":        { "$type": "color", "$value": "{color.text.primary}", "$description": "Drag-over text" },
      "file-text":        { "$type": "color", "$value": "{color.text.base}", "$description": "File name text" },
      "file-size":        { "$type": "color", "$value": "{color.text.muted}", "$description": "File size text" },
      "file-icon":        { "$type": "color", "$value": "{color.text.muted}", "$description": "File type icon" },
      "file-remove":      { "$type": "color", "$value": "{color.text.muted}", "$description": "Remove button" },
      "file-remove-hover": { "$type": "color", "$value": "{color.text.error}", "$description": "Remove hover" },
      "progress-bg":      { "$type": "color", "$value": "{color.bg.surface-hover}", "$description": "Progress track" },
      "progress-fill":    { "$type": "color", "$value": "{color.bg.primary}", "$description": "Progress bar" },
      "error-text":       { "$type": "color", "$value": "{color.text.error}", "$description": "Error message" },
      "error-border":     { "$type": "color", "$value": "{color.border.error}", "$description": "Error zone border" }
    }
  },
  "radius": {
    "fileupload": {
      "zone":     { "$type": "dimension", "$value": "{radius.component.lg}", "$description": "Zone radius" },
      "item":     { "$type": "dimension", "$value": "{radius.component.md}", "$description": "File item radius" },
      "progress": { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Pill progress bar" }
    }
  },
  "spacing": {
    "fileupload": {
      "zone-padding":  { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "Zone inner padding" },
      "file-gap":      { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between file items" },
      "file-item-gap": { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap inside file item row (12px)" },
      "list-padding":  { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "File list container padding (12px)" },
      "item-padding":  { "$type": "dimension", "$value": "{spacing.component.padding.sm}", "$description": "File item padding (8px)" },
      "remove-padding": { "$type": "dimension", "$value": "{spacing.component.padding.xs}", "$description": "Remove button padding (4px)" },
      "progress-px":   { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "Progress bar horizontal padding" },
      "progress-pb":   { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "Progress bar bottom padding" },
      "subtext-mt":    { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Sub-text top margin (4px)" },
      "addmore-mt":    { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Add-more hint top margin (8px)" }
    }
  },
  "font": {
    "fileupload": {
      "instruction-size":   { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Instruction text size (14px)" },
      "instruction-weight": { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Instruction text weight" },
      "filename-size":      { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "File name size (14px)" },
      "hint-size":          { "$type": "dimension", "$value": "{font.component.size.xs}", "$description": "Hint/sub/size text (12px)" }
    }
  }
}
