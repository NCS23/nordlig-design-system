{
  "color": {
    "$description": "Level 4: Button component tokens - References Level 3 only",
    "btn": {
      "primary": {
        "bg":        { "$type": "color", "$value": "{color.bg.primary}" },
        "bg-hover":  { "$type": "color", "$value": "{color.bg.primary-hover}" },
        "bg-active": { "$type": "color", "$value": "{color.bg.primary-active}" },
        "text":      { "$type": "color", "$value": "{color.text.inverse}" },
        "border":    { "$type": "color", "$value": "{color.bg.primary}" }
      },
      "secondary": {
        "bg":        { "$type": "color", "$value": "{color.bg.surface}" },
        "bg-hover":  { "$type": "color", "$value": "{color.bg.surface-hover}" },
        "bg-active": { "$type": "color", "$value": "{color.bg.surface-active}" },
        "text":      { "$type": "color", "$value": "{color.text.base}" },
        "border":    { "$type": "color", "$value": "{color.border.default}" }
      },
      "ghost": {
        "bg-hover":  { "$type": "color", "$value": "{color.bg.surface}" },
        "bg-active": { "$type": "color", "$value": "{color.bg.surface-hover}" },
        "text":      { "$type": "color", "$value": "{color.text.primary}" }
      },
      "disabled": {
        "bg":   { "$type": "color", "$value": "{color.interactive.primary-disabled}" },
        "text": { "$type": "color", "$value": "{color.text.disabled}" }
      }
    }
  },
  "sizing": {
    "$description": "Level 4: Button size tokens — References Level 3 only",
    "btn": {
      "sm": {
        "height":    { "$type": "dimension", "$value": "{sizing.component.height.sm}" },
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.sm}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.sm}" },
        "gap":       { "$type": "dimension", "$value": "{sizing.component.gap.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.sm}" },
        "radius":    { "$type": "dimension", "$value": "{radius.component.md}" }
      },
      "md": {
        "height":    { "$type": "dimension", "$value": "{sizing.component.height.md}" },
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.md}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.md}" },
        "gap":       { "$type": "dimension", "$value": "{sizing.component.gap.md}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.md}" },
        "radius":    { "$type": "dimension", "$value": "{radius.component.md}" }
      },
      "lg": {
        "height":    { "$type": "dimension", "$value": "{sizing.component.height.lg}" },
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.lg}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.lg}" },
        "gap":       { "$type": "dimension", "$value": "{sizing.component.gap.lg}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.lg}" },
        "radius":    { "$type": "dimension", "$value": "{radius.component.md}" }
      }
    }
  },
  "spacing": {
    "btn": {
      "padding-x": { "$type": "dimension", "$value": "{spacing.component.padding.md}" },
      "padding-y": { "$type": "dimension", "$value": "{spacing.component.padding.sm}" },
      "gap":       { "$type": "dimension", "$value": "{spacing.component.gap.sm}" }
    }
  }
}
