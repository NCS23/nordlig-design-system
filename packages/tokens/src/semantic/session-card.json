{
  "color": {
    "$description": "Level 4: SessionCard component tokens",
    "session-card": {
      "bg":             { "$type": "color", "$value": "{color.bg.paper}", "$description": "Card background" },
      "border":         { "$type": "color", "$value": "{color.border.muted}", "$description": "Default border" },
      "border-hover":   { "$type": "color", "$value": "{color.border.default}", "$description": "Hover border" },
      "bg-hover":       { "$type": "color", "$value": "{color.bg.surface}", "$description": "Hover background" },
      "bg-error":       { "$type": "color", "$value": "{color.bg.error-subtle}", "$description": "Error state background" },
      "border-error":   { "$type": "color", "$value": "{color.border.error}", "$description": "Error state border" },
      "text-primary":   { "$type": "color", "$value": "{color.text.base}", "$description": "Title and value text" },
      "text-secondary": { "$type": "color", "$value": "{color.text.muted}", "$description": "Date, labels, description" },
      "text-tertiary":  { "$type": "color", "$value": "{color.text.disabled}", "$description": "Zone labels (Z1-Z5)" },
      "text-error":     { "$type": "color", "$value": "{color.text.error}", "$description": "Error message text" },
      "skeleton":       { "$type": "color", "$value": "{color.bg.surface}", "$description": "Skeleton placeholder" },
      "zone-bg":        { "$type": "color", "$value": "{color.bg.surface}", "$description": "Zone bar background" },
      "zone-1":         { "$type": "color", "$value": "{color.border.strong}", "$description": "HR Zone 1 Recovery" },
      "zone-2":         { "$type": "color", "$value": "{color.border.success}", "$description": "HR Zone 2 Aerobic" },
      "zone-3":         { "$type": "color", "$value": "{color.border.warning}", "$description": "HR Zone 3 Tempo" },
      "zone-4":         { "$type": "color", "$value": "{color.text.warning}", "$description": "HR Zone 4 Threshold" },
      "zone-5":         { "$type": "color", "$value": "{color.border.error}", "$description": "HR Zone 5 Maximum" },
      "focus-ring":     { "$type": "color", "$value": "{color.border.focus}", "$description": "Focus ring for interactive state" }
    }
  },
  "radius": {
    "session-card": { "$type": "dimension", "$value": "{radius.component.lg}", "$description": "Card border radius" }
  },
  "spacing": {
    "session-card": {
      "grid-gap": { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Gap between grid items (16px)" }
    }
  }
}
