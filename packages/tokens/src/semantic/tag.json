{
  "color": {
    "$description": "Level 4: Tag component tokens",
    "tag": {
      "bg-default": {
        "$type": "color",
        "$value": "{color.bg.surface}",
        "$description": "Default tag background"
      },
      "bg-success": {
        "$type": "color",
        "$value": "{color.bg.success-subtle}",
        "$description": "Success variant background"
      },
      "bg-warning": {
        "$type": "color",
        "$value": "{color.bg.warning-subtle}",
        "$description": "Warning variant background"
      },
      "bg-error": {
        "$type": "color",
        "$value": "{color.bg.error-subtle}",
        "$description": "Error variant background"
      },
      "bg-info": {
        "$type": "color",
        "$value": "{color.bg.info-subtle}",
        "$description": "Info variant background"
      },
      "text-default": {
        "$type": "color",
        "$value": "{color.text.base}",
        "$description": "Default tag text color"
      },
      "text-success": {
        "$type": "color",
        "$value": "{color.text.success}",
        "$description": "Success variant text color"
      },
      "text-warning": {
        "$type": "color",
        "$value": "{color.text.warning}",
        "$description": "Warning variant text color"
      },
      "text-error": {
        "$type": "color",
        "$value": "{color.text.error}",
        "$description": "Error variant text color"
      },
      "text-info": {
        "$type": "color",
        "$value": "{color.text.info}",
        "$description": "Info variant text color"
      },
      "border-default": {
        "$type": "color",
        "$value": "{color.border.muted}",
        "$description": "Default tag border"
      },
      "border-success": {
        "$type": "color",
        "$value": "{color.border.success}",
        "$description": "Success variant border"
      },
      "border-warning": {
        "$type": "color",
        "$value": "{color.border.warning}",
        "$description": "Warning variant border"
      },
      "border-error": {
        "$type": "color",
        "$value": "{color.border.error}",
        "$description": "Error variant border"
      },
      "border-info": {
        "$type": "color",
        "$value": "{color.border.info}",
        "$description": "Info variant border"
      },
      "border-focus": {
        "$type": "color",
        "$value": "{color.border.focus}",
        "$description": "Focus ring color"
      }
    }
  },
  "radius": {
    "tag": {
      "$type": "dimension",
      "$value": "{radius.component.md}",
      "$description": "Tag border radius"
    },
    "tag-dismiss": {
      "$type": "dimension",
      "$value": "{radius.component.full}",
      "$description": "Dismiss button border radius (fully round)"
    }
  },
  "sizing": {
    "tag": {
      "border-width": { "$type": "dimension", "$value": "{sizing.component.border-width.default}", "$description": "Tag border width (1px)" }
    }
  },
  "spacing": {
    "tag": {
      "gap":        { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Gap between text and remove icon (4px)" },
      "sm-px":      { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "8px horizontal padding for sm size" },
      "sm-py":      { "$type": "dimension", "$value": "{spacing.component.gap.2xs}", "$description": "2px vertical padding for sm size" },
      "md-px":      { "$type": "dimension", "$value": "{spacing.component.padding.sm}", "$description": "12px horizontal padding for md size" },
      "md-py":      { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "4px vertical padding for md size" },
      "dismiss-p":  { "$type": "dimension", "$value": "{spacing.component.gap.2xs}", "$description": "2px padding for dismiss button" }
    }
  },
  "font": {
    "tag": {
      "weight":  { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Tag font weight (500)" },
      "sm-size": { "$type": "dimension", "$value": "{font.component.size.xs}", "$description": "Tag sm font size (12px)" },
      "md-size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Tag md font size (14px)" }
    }
  }
}
