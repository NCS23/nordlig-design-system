{
  "color": {
    "$description": "Level 4: Badge component tokens",
    "badge": {
      "success": {
        "bg":     { "$type": "color", "$value": "{color.success.bg}" },
        "text":   { "$type": "color", "$value": "{color.success.text}" },
        "border": { "$type": "color", "$value": "{color.success.border}" }
      },
      "warning": {
        "bg":     { "$type": "color", "$value": "{color.warning.bg}" },
        "text":   { "$type": "color", "$value": "{color.warning.text}" },
        "border": { "$type": "color", "$value": "{color.warning.border}" }
      },
      "error": {
        "bg":     { "$type": "color", "$value": "{color.error.bg}" },
        "text":   { "$type": "color", "$value": "{color.error.text}" },
        "border": { "$type": "color", "$value": "{color.error.border}" }
      },
      "info": {
        "bg":     { "$type": "color", "$value": "{color.info.bg}" },
        "text":   { "$type": "color", "$value": "{color.info.text}" },
        "border": { "$type": "color", "$value": "{color.info.border}" }
      },
      "neutral": {
        "bg":     { "$type": "color", "$value": "{color.bg.surface}" },
        "text":   { "$type": "color", "$value": "{color.text.muted}" },
        "border": { "$type": "color", "$value": "{color.border.muted}" }
      }
    }
  },
  "sizing": {
    "$description": "Level 4: Badge size tokens — References Level 3 only",
    "badge": {
      "sm": {
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.sm}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.sm}" },
        "line-height": { "$type": "dimension", "$value": "{font.component.line-height.sm}", "$description": "21px" }
      },
      "md": {
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.md}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.sm}" },
        "line-height": { "$type": "dimension", "$value": "{font.component.line-height.sm}", "$description": "21px" }
      },
      "lg": {
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.md}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.md}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.md}" },
        "line-height": { "$type": "dimension", "$value": "{font.component.line-height.md}", "$description": "24px" }
      }
    }
  },
  "radius": {
    "badge": { "$type": "dimension", "$value": "{radius.component.full}" }
  },
  "font": {
    "$description": "Level 4: Badge typography tokens",
    "badge": {
      "weight": { "$type": "fontWeight", "$value": "{font.weight.medium}", "$description": "Font weight 500 (medium)" }
    }
  }
}
