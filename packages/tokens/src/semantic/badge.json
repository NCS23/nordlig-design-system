{
  "color": {
    "$description": "Level 4: Badge component tokens",
    "badge": {
      "success": {
        "bg":     { "$type": "color", "$value": "{color.bg.success}" },
        "text":   { "$type": "color", "$value": "{color.text.success}" },
        "border": { "$type": "color", "$value": "{color.border.success}" }
      },
      "warning": {
        "bg":     { "$type": "color", "$value": "{color.bg.warning}" },
        "text":   { "$type": "color", "$value": "{color.text.warning}" },
        "border": { "$type": "color", "$value": "{color.border.warning}" }
      },
      "error": {
        "bg":     { "$type": "color", "$value": "{color.bg.error}" },
        "text":   { "$type": "color", "$value": "{color.text.error}" },
        "border": { "$type": "color", "$value": "{color.border.error}" }
      },
      "info": {
        "bg":     { "$type": "color", "$value": "{color.bg.info}" },
        "text":   { "$type": "color", "$value": "{color.text.info}" },
        "border": { "$type": "color", "$value": "{color.border.info}" }
      },
      "neutral": {
        "bg":     { "$type": "color", "$value": "{color.bg.surface}" },
        "text":   { "$type": "color", "$value": "{color.text.muted}" },
        "border": { "$type": "color", "$value": "{color.border.muted}" }
      },
      "primary": {
        "bg":     { "$type": "color", "$value": "{color.primary.1.100}", "$description": "Sky-100 — clearly visible light blue" },
        "text":   { "$type": "color", "$value": "{color.primary.1.700}" },
        "border": { "$type": "color", "$value": "{color.primary.1.300}" }
      },
      "primary-bold": {
        "bg":     { "$type": "color", "$value": "{color.primary.1.200}", "$description": "Sky-200 — stronger blue for emphasis" },
        "text":   { "$type": "color", "$value": "{color.primary.1.800}" },
        "border": { "$type": "color", "$value": "{color.primary.1.400}" }
      },
      "accent": {
        "bg":     { "$type": "color", "$value": "{color.primary.2.100}", "$description": "Indigo-100 — clearly visible violet" },
        "text":   { "$type": "color", "$value": "{color.primary.2.700}" },
        "border": { "$type": "color", "$value": "{color.primary.2.300}" }
      },
      "accent-bold": {
        "bg":     { "$type": "color", "$value": "{color.primary.2.200}", "$description": "Indigo-200 — stronger violet for emphasis" },
        "text":   { "$type": "color", "$value": "{color.primary.2.800}" },
        "border": { "$type": "color", "$value": "{color.primary.2.400}" }
      }
    }
  },
  "sizing": {
    "$description": "Level 4: Badge size tokens — References Level 3 only",
    "badge": {
      "border-width": { "$type": "dimension", "$value": "{sizing.component.border-width.default}", "$description": "Badge border width (1px)" },
      "xs": {
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.xs}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.xs}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.xs}" }
      },
      "sm": {
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.sm}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.sm}" }
      },
      "md": {
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.md}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.sm}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.sm}" }
      },
      "lg": {
        "padding-x": { "$type": "dimension", "$value": "{sizing.component.padding-x.md}" },
        "padding-y": { "$type": "dimension", "$value": "{sizing.component.padding-y.md}" },
        "font-size": { "$type": "dimension", "$value": "{font.component.size.md}" }
      }
    }
  },
  "radius": {
    "badge": { "$type": "dimension", "$value": "{radius.component.full}" }
  },
  "font": {
    "$description": "Level 4: Badge typography tokens",
    "badge": {
      "weight": { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Font weight 500 (medium)" }
    }
  }
}
