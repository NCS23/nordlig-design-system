{
  "color": {
    "$description": "Level 4: CopyButton component tokens",
    "cpybtn": {
      "bg":          { "$type": "color", "$value": "{color.bg.surface}", "$description": "Default background" },
      "bg-hover":    { "$type": "color", "$value": "{color.bg.surface-hover}", "$description": "Hover background" },
      "icon":        { "$type": "color", "$value": "{color.text.muted}", "$description": "Copy icon color" },
      "icon-copied": { "$type": "color", "$value": "{color.text.success}", "$description": "Check icon after copy" },
      "border":      { "$type": "color", "$value": "{color.border.default}", "$description": "Button border" }
    }
  },
  "radius": {
    "cpybtn": { "$type": "dimension", "$value": "{radius.component.md}", "$description": "Button radius" }
  },
  "sizing": {
    "cpybtn": {
      "sm": { "$type": "dimension", "$value": "28px", "$description": "CopyButton size sm (compact icon-only)" },
      "md": { "$type": "dimension", "$value": "32px", "$description": "CopyButton size md" },
      "lg": { "$type": "dimension", "$value": "36px", "$description": "CopyButton size lg" }
    }
  }
}
