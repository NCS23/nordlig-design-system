{
  "color": {
    "$description": "Level 4: Spinner component tokens — References Level 3 only",
    "spinner": {
      "primary": { "$type": "color", "$value": "{color.interactive.primary}" },
      "track":   { "$type": "color", "$value": "{color.border.muted}" },
      "label":   { "$type": "color", "$value": "{color.text.muted}" }
    }
  },
  "font": {
    "spinner": {
      "label-size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Spinner label font size (text-sm)" }
    }
  },
  "sizing": {
    "$description": "Level 4: Spinner size tokens — icon-sized dimensions",
    "spinner": {
      "sm": { "$type": "dimension", "$value": "{sizing.component.icon.sm}" },
      "md": { "$type": "dimension", "$value": "{sizing.component.icon.md}" },
      "lg": { "$type": "dimension", "$value": "{sizing.component.icon.lg}" },
      "xl": { "$type": "dimension", "$value": "{sizing.component.icon.xl}" }
    }
  }
}
