{
  "color": {
    "$description": "Level 4: Timeline component tokens",
    "timeline": {
      "dot-default-bg":    { "$type": "color", "$value": "{color.bg.surface}", "$description": "Default dot background" },
      "dot-default-text":  { "$type": "color", "$value": "{color.text.muted}", "$description": "Default dot icon" },
      "dot-success-bg":    { "$type": "color", "$value": "{color.bg.success-subtle}", "$description": "Success dot — subtle green" },
      "dot-success-text":  { "$type": "color", "$value": "{color.text.success}", "$description": "Success dot icon (dark green)" },
      "dot-warning-bg":    { "$type": "color", "$value": "{color.bg.warning-subtle}", "$description": "Warning dot — subtle amber" },
      "dot-warning-text":  { "$type": "color", "$value": "{color.text.warning}", "$description": "Warning dot icon (dark amber)" },
      "dot-error-bg":      { "$type": "color", "$value": "{color.bg.error-subtle}", "$description": "Error dot — subtle red" },
      "dot-error-text":    { "$type": "color", "$value": "{color.text.error}", "$description": "Error dot icon (dark red)" },
      "inner-dot-default": { "$type": "color", "$value": "{color.text.muted}", "$description": "Default inner dot" },
      "inner-dot-variant": { "$type": "color", "$value": "{color.bg.paper}", "$description": "Variant inner dot" },
      "line":              { "$type": "color", "$value": "{color.border.muted}", "$description": "Connecting line — softer" },
      "title":             { "$type": "color", "$value": "{color.text.base}", "$description": "Item title" },
      "description":       { "$type": "color", "$value": "{color.text.muted}", "$description": "Item description" },
      "timestamp":         { "$type": "color", "$value": "{color.text.muted}", "$description": "Item timestamp" }
    }
  },
  "radius": {
    "timeline": {
      "dot":       { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Circular dot (9999px)" },
      "inner-dot": { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Circular inner dot (9999px)" }
    }
  },
  "spacing": {
    "$description": "Level 4: Timeline component tokens",
    "timeline": {
      "item-pb":    { "$type": "dimension", "$value": "{spacing.component.padding.xl}", "$description": "32px item bottom padding" },
      "line-left":  { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px line left offset" },
      "line-top":   { "$type": "dimension", "$value": "{spacing.component.padding.xl}", "$description": "32px line top offset" },
      "content-ml": { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px content left margin" },
      "desc-mt":    { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "8px description margin top" },
      "desc-text-mt": { "$type": "dimension", "$value": "{spacing.component.gap.2xs}", "$description": "2px description text margin top" }
    }
  },
  "sizing": {
    "timeline": {
      "dot":       { "$type": "dimension", "$value": "{spacing.component.padding.xl}", "$description": "32px dot diameter" },
      "inner-dot": { "$type": "dimension", "$value": "10px", "$description": "10px inner dot" },
      "line-w":    { "$type": "dimension", "$value": "{sizing.component.border-width.default}", "$description": "1px line width (reduced from 2px)" }
    }
  },
  "font": {
    "timeline": {
      "timestamp-size": { "$type": "dimension",   "$value": "{font.component.size.xs}",       "$description": "Timestamp text size (12px)" },
      "title-size":     { "$type": "dimension",   "$value": "{font.component.size.sm}",       "$description": "Title text size (14px)" },
      "title-weight":   { "$type": "fontWeight",   "$value": "{font.component.weight.medium}",  "$description": "Title text weight" },
      "desc-size":      { "$type": "dimension",   "$value": "{font.component.size.sm}",       "$description": "Description text size (14px)" }
    }
  }
}
