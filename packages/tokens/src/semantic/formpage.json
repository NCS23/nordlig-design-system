{
  "spacing": {
    "formpage": {
      "header-gap":  { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Gap below header section (16px)" },
      "body-gap":    { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap between form fields (8px)" },
      "actions-gap": { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between action buttons (8px)" }
    }
  },
  "sizing": {
    "formpage": {
      "max-width-sm": { "$type": "dimension", "$value": "480px", "$description": "Narrow form (login, simple)" },
      "max-width-md": { "$type": "dimension", "$value": "640px", "$description": "Medium form (default)" },
      "max-width-lg": { "$type": "dimension", "$value": "800px", "$description": "Wide form (complex)" }
    }
  }
}
