{
  "color": {
    "$description": "Level 4: Tooltip component tokens",
    "tooltip": {
      "bg":    { "$type": "color", "$value": "{color.text.base}", "$description": "Dark tooltip background" },
      "text":  { "$type": "color", "$value": "{color.text.inverse}", "$description": "Light text on dark bg" },
      "arrow": { "$type": "color", "$value": "{color.text.base}", "$description": "Arrow matches bg" }
    }
  },
  "shadow": {
    "tooltip": { "$type": "shadow", "$value": "{shadow.elevation.medium}", "$description": "Tooltip elevation" }
  },
  "radius": {
    "tooltip": { "$type": "dimension", "$value": "{radius.component.md}", "$description": "6px rounded corners" }
  },
  "spacing": {
    "tooltip": {
      "padding-x": { "$type": "dimension", "$value": "{spacing.component.padding.sm}", "$description": "12px horizontal padding" },
      "padding-y": { "$type": "dimension", "$value": "{spacing.component.padding.xs}", "$description": "8px vertical padding" }
    }
  }
}
