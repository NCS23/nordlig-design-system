{
  "color": {
    "$description": "Level 4: Modal/Dialog component tokens",
    "modal": {
      "overlay":          { "$type": "color", "$value": "{color.bg.overlay}", "$description": "Dark backdrop behind modal" },
      "bg":               { "$type": "color", "$value": "{color.bg.paper}", "$description": "White content background" },
      "title":            { "$type": "color", "$value": "{color.text.base}", "$description": "Modal title text" },
      "description":      { "$type": "color", "$value": "{color.text.muted}", "$description": "Modal description text" },
      "divider":          { "$type": "color", "$value": "{color.border.muted}", "$description": "Header/footer border" },
      "close-hover-bg":   { "$type": "color", "$value": "{color.bg.surface}", "$description": "Close button hover bg" },
      "close-hover-text": { "$type": "color", "$value": "{color.interactive.primary}", "$description": "Close button hover color (sky blue)" }
    }
  },
  "shadow": {
    "modal": {
      "content": { "$type": "shadow", "$value": "{shadow.elevation.overlay}", "$description": "Prominent modal shadow" }
    }
  },
  "radius": {
    "modal": { "$type": "dimension", "$value": "{radius.component.lg}", "$description": "8px rounded corners" }
  },
  "spacing": {
    "modal": {
      "padding-x": { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "24px horizontal padding" },
      "padding-y": { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px vertical padding" },
      "gap":       { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "8px footer button gap" }
    }
  }
}
