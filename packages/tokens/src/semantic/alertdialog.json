{
  "color": {
    "$description": "Level 4: AlertDialog component tokens",
    "alertdlg": {
      "overlay":     { "$type": "color", "$value": "{color.bg.overlay}", "$description": "AlertDialog backdrop overlay" },
      "bg":          { "$type": "color", "$value": "{color.bg.paper}", "$description": "AlertDialog content background" },
      "title":       { "$type": "color", "$value": "{color.text.base}", "$description": "AlertDialog title text" },
      "description": { "$type": "color", "$value": "{color.text.muted}", "$description": "AlertDialog description text" },
      "border":      { "$type": "color", "$value": "{color.border.muted}", "$description": "AlertDialog border" },
      "action-bg":   { "$type": "color", "$value": "{color.error.bg}", "$description": "Destructive action button background" },
      "action-text": { "$type": "color", "$value": "{color.text.inverse}", "$description": "Destructive action button text" },
      "action-hover-bg": { "$type": "color", "$value": "{color.error.text}", "$description": "Destructive action button hover" },
      "cancel-bg":   { "$type": "color", "$value": "{color.bg.surface}", "$description": "Cancel button background" },
      "cancel-text": { "$type": "color", "$value": "{color.text.base}", "$description": "Cancel button text" },
      "cancel-hover-bg": { "$type": "color", "$value": "{color.bg.surface-hover}", "$description": "Cancel button hover" }
    }
  },
  "shadow": {
    "alertdlg": { "$type": "shadow", "$value": "{shadow.elevation.overlay}", "$description": "AlertDialog panel shadow" }
  },
  "radius": {
    "alertdlg": { "$type": "dimension", "$value": "{radius.component.lg}", "$description": "AlertDialog border radius" }
  },
  "spacing": {
    "alertdlg": {
      "padding": { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "AlertDialog content padding" },
      "gap":     { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "AlertDialog content gap" }
    }
  }
}
