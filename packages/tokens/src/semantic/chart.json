{
  "color": {
    "$description": "Level 4: Chart component tokens",
    "chart": {
      "1":              { "$type": "color", "$value": "{color.bg.primary}", "$description": "Chart color 1 (primary blue)" },
      "2":              { "$type": "color", "$value": "{color.text.success}", "$description": "Chart color 2 (green)" },
      "3":              { "$type": "color", "$value": "{color.text.warning}", "$description": "Chart color 3 (amber)" },
      "4":              { "$type": "color", "$value": "{color.text.error}", "$description": "Chart color 4 (red)" },
      "5":              { "$type": "color", "$value": "{color.text.info}", "$description": "Chart color 5 (info blue)" },
      "axis":           { "$type": "color", "$value": "{color.text.muted}", "$description": "Chart axis text color" },
      "tooltip-bg":     { "$type": "color", "$value": "{color.bg.paper}", "$description": "Chart tooltip background" },
      "tooltip-border": { "$type": "color", "$value": "{color.border.muted}", "$description": "Chart tooltip border" },
      "tooltip-text":   { "$type": "color", "$value": "{color.text.base}", "$description": "Chart tooltip text" }
    }
  },
  "font": {
    "chart": {
      "tooltip-size":      { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Chart tooltip font size" },
      "tooltip-weight":    { "$type": "dimension", "$value": "{font.component.weight.medium}", "$description": "Chart tooltip label/value font weight" },
      "legend-size":       { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Chart legend item font size" }
    }
  },
  "shadow": {
    "chart": {
      "tooltip": { "$type": "shadow", "$value": "{shadow.elevation.floating}", "$description": "Chart tooltip shadow" }
    }
  },
  "radius": {
    "chart": {
      "tooltip":    { "$type": "dimension", "$value": "{radius.component.md}", "$description": "Chart tooltip border radius" },
      "indicator":  { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Indicator border radius (full)" },
      "legend-dot": { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Legend dot border radius (full)" }
    }
  },
  "spacing": {
    "chart": {
      "tooltip-gap":      { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Gap in tooltip items (4px)" },
      "legend-gap":       { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Gap between legend items (16px)" },
      "legend-item-gap":  { "$type": "dimension", "$value": "{sizing.component.gap.sm}", "$description": "Gap within legend item (6px)" },
      "tooltip-px":       { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Tooltip horizontal padding (12px)" },
      "tooltip-py":       { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Tooltip vertical padding (8px)" },
      "tooltip-label-mb": { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Tooltip label bottom margin (4px)" },
      "legend-pt":        { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Legend top padding (12px)" }
    }
  },
  "sizing": {
    "chart": {
      "indicator-dot":    { "$type": "dimension", "$value": "{sizing.component.indicator.dot-md}", "$description": "Tooltip dot indicator size (10px)" },
      "indicator-line-h": { "$type": "dimension", "$value": "{spacing.component.gap.2xs}", "$description": "Line indicator height (2px)" },
      "indicator-line-w": { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Line indicator width (14px)" },
      "legend-dot":       { "$type": "dimension", "$value": "{sizing.component.indicator.dot-md}", "$description": "Legend dot size (10px)" }
    }
  }
}
