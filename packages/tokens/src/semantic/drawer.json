{
  "color": {
    "$description": "Level 4: Drawer component tokens",
    "drawer": {
      "overlay":     { "$type": "color", "$value": "{color.bg.overlay}", "$description": "Drawer backdrop overlay" },
      "bg":          { "$type": "color", "$value": "{color.bg.paper}", "$description": "Drawer content background" },
      "title":       { "$type": "color", "$value": "{color.text.base}", "$description": "Drawer title text" },
      "description": { "$type": "color", "$value": "{color.text.muted}", "$description": "Drawer description text" },
      "border":      { "$type": "color", "$value": "{color.border.muted}", "$description": "Drawer top border" },
      "handle":      { "$type": "color", "$value": "{color.border.strong}", "$description": "Drag handle bar color" }
    }
  },
  "shadow": {
    "drawer": { "$type": "shadow", "$value": "{shadow.elevation.floating}", "$description": "Drawer elevation shadow" }
  },
  "radius": {
    "drawer": { "$type": "dimension", "$value": "{radius.component.xl}", "$description": "12px drawer radius (large overlay)" },
    "drawer-handle": { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Pill-shaped handle bar (9999px)" }
  },
  "sizing": {
    "drawer": {
      "handle-h": { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "6px handle height" },
      "handle-w": { "$type": "dimension", "$value": "{spacing.component.padding.xl}", "$description": "48px handle width" }
    }
  },
  "spacing": {
    "drawer": {
      "padding":   { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "Drawer content padding" },
      "gap":       { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Drawer section gap" },
      "handle-mt": { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px handle top margin" },
      "footer-pt": { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "8px footer top padding" }
    }
  },
  "font": {
    "drawer": {
      "title-size":       { "$type": "dimension", "$value": "{font.component.size.lg}", "$description": "Drawer title font size (text-lg equivalent)" },
      "title-weight":     { "$type": "fontWeight", "$value": "{font.component.weight.semibold}", "$description": "Drawer title font weight (font-semibold)" },
      "description-size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Drawer description font size (text-sm equivalent)" }
    }
  }
}
