{
  "color": {
    "$description": "Level 4: Dialog component tokens",
    "dialog": {
      "overlay":     { "$type": "color", "$value": "{color.bg.overlay}", "$description": "Dialog backdrop overlay" },
      "bg":          { "$type": "color", "$value": "{color.bg.elevated}", "$description": "Dialog content background" },
      "title":       { "$type": "color", "$value": "{color.text.base}", "$description": "Dialog title text" },
      "description": { "$type": "color", "$value": "{color.text.muted}", "$description": "Dialog description text" },
      "border":      { "$type": "color", "$value": "{color.border.muted}", "$description": "Dialog border" }
    }
  },
  "shadow": {
    "dialog": { "$type": "shadow", "$value": "{shadow.elevation.floating}", "$description": "Dialog panel shadow" }
  },
  "radius": {
    "dialog": { "$type": "dimension", "$value": "{radius.component.xl}", "$description": "12px dialog radius (large overlay)" }
  },
  "spacing": {
    "dialog": {
      "padding": { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "Dialog content padding" },
      "gap":     { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Dialog content gap" }
    }
  },
  "font": {
    "dialog": {
      "title-size":       { "$type": "dimension", "$value": "{font.component.size.lg}", "$description": "Dialog title font size (text-lg equivalent)" },
      "title-weight":     { "$type": "fontWeight", "$value": "{font.component.weight.semibold}", "$description": "Dialog title font weight (font-semibold)" },
      "description-size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Dialog description font size (text-sm equivalent)" }
    }
  }
}
