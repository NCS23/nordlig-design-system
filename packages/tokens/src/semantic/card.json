{
  "color": {
    "$description": "Level 4: Card component tokens",
    "card": {
      "bg":          { "$type": "color", "$value": "{color.bg.elevated}", "$description": "Default card background" },
      "bg-raised":   { "$type": "color", "$value": "{color.bg.elevated}", "$description": "Raised card background" },
      "bg-elevated": { "$type": "color", "$value": "{color.bg.elevated}", "$description": "Elevated card background" },
      "border":      { "$type": "color", "$value": "{color.border.muted}" }
    }
  },
  "spacing": {
    "card": {
      "padding-compact":  { "$type": "dimension", "$value": "{spacing.component.padding.sm}" },
      "padding-normal":   { "$type": "dimension", "$value": "{spacing.base.5}", "$description": "20px card padding (all sides except bottom)" },
      "padding-spacious": { "$type": "dimension", "$value": "{spacing.component.padding.lg}" },
      "padding-bottom":   { "$type": "dimension", "$value": "{spacing.base.8}", "$description": "32px card bottom padding" },
      "gap":              { "$type": "dimension", "$value": "{spacing.base.5}", "$description": "20px gap between card sections" }
    }
  },
  "shadow": {
    "card": {
      "raised":   { "$type": "shadow", "$value": "{shadow.elevation.raised}" },
      "elevated": { "$type": "shadow", "$value": "{shadow.elevation.floating}" },
      "hover":    { "$type": "shadow", "$value": "{shadow.elevation.floating}" }
    }
  },
  "radius": {
    "card": { "$type": "dimension", "$value": "{radius.component.lg}" }
  }
}
