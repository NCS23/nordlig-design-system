{
  "color": {
    "$description": "Level 4: Card component tokens",
    "card": {
      "bg":     { "$type": "color", "$value": "{color.bg.surface}" },
      "border": { "$type": "color", "$value": "{color.border.muted}" }
    }
  },
  "spacing": {
    "card": {
      "padding-compact":  { "$type": "dimension", "$value": "{spacing.component.padding.sm}" },
      "padding-normal":   { "$type": "dimension", "$value": "{spacing.component.padding.md}" },
      "padding-spacious": { "$type": "dimension", "$value": "{spacing.component.padding.lg}" },
      "gap":              { "$type": "dimension", "$value": "{spacing.component.gap.md}" }
    }
  },
  "shadow": {
    "card": {
      "raised":   { "$type": "shadow", "$value": "{shadow.elevation.low}" },
      "elevated": { "$type": "shadow", "$value": "{shadow.elevation.medium}" }
    }
  },
  "radius": {
    "card": { "$type": "dimension", "$value": "{radius.component.lg}" }
  }
}
