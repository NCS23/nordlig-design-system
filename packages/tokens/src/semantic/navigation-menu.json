{
  "color": {
    "$description": "Level 4: NavigationMenu component tokens",
    "nav": {
      "text":            { "$type": "color", "$value": "{color.text.base}", "$description": "Navigation item text" },
      "hover-bg":        { "$type": "color", "$value": "{color.bg.surface}", "$description": "Item hover background" },
      "active-bg":       { "$type": "color", "$value": "{color.bg.surface}", "$description": "Active item background" },
      "dropdown-bg":     { "$type": "color", "$value": "{color.bg.paper}", "$description": "Dropdown panel background" },
      "dropdown-border": { "$type": "color", "$value": "{color.border.muted}", "$description": "Dropdown panel border" },
      "focus-ring":      { "$type": "color", "$value": "{color.border.focus}", "$description": "Focus ring color" }
    }
  },
  "shadow": {
    "nav": {
      "dropdown": { "$type": "shadow", "$value": "{shadow.elevation.floating}", "$description": "Dropdown panel shadow" }
    }
  },
  "radius": {
    "nav":          { "$type": "dimension", "$value": "{radius.component.md}", "$description": "Navigation item radius" },
    "nav-dropdown": { "$type": "dimension", "$value": "{radius.component.lg}", "$description": "Dropdown panel radius" }
  },
  "spacing": {
    "navmenu": {
      "gap":          { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Gap between nav items (4px)" },
      "trigger-px":   { "$type": "dimension", "$value": "{spacing.component.padding.sm}", "$description": "12px trigger horizontal padding" },
      "trigger-py":   { "$type": "dimension", "$value": "{spacing.component.padding.xs}", "$description": "8px trigger vertical padding" },
      "content-p":    { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px content padding" },
      "indicator-mt": { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "4px indicator margin-top" }
    }
  },
  "font": {
    "nav": {
      "trigger-size":   { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Trigger text font size (text-sm equivalent)" },
      "trigger-weight": { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Trigger text font weight (font-medium)" },
      "link-size":      { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Link text font size (text-sm equivalent)" },
      "link-weight":    { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Active link font weight (font-medium)" }
    }
  }
}
