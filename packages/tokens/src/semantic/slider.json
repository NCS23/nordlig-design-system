{
  "color": {
    "$description": "Level 4: Slider component tokens",
    "slider": {
      "track":        { "$type": "color", "$value": "{color.bg.surface}", "$description": "Slider track background" },
      "range":        { "$type": "color", "$value": "{color.bg.primary}", "$description": "Slider filled range" },
      "thumb":        { "$type": "color", "$value": "{color.bg.paper}", "$description": "Slider thumb background" },
      "thumb-border": { "$type": "color", "$value": "{color.bg.primary}", "$description": "Slider thumb border" },
      "thumb-hover":  { "$type": "color", "$value": "{color.bg.primary-hover}", "$description": "Slider thumb hover border" }
    }
  },
  "font": {
    "slider": {
      "value-size":   { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Slider value display font size (text-sm)" },
      "value-weight": { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Slider value display font weight (500)" }
    }
  },
  "sizing": {
    "slider": {
      "track-height":       { "$type": "dimension", "$value": "{sizing.component.track.md}", "$description": "Slider track height (8px)" },
      "thumb-size":         { "$type": "dimension", "$value": "{sizing.component.icon.control}", "$description": "Slider thumb size (20px)" },
      "thumb-border-width": { "$type": "dimension", "$value": "{sizing.component.border-width.thick}", "$description": "Slider thumb border width (2px)" }
    }
  },
  "spacing": {
    "slider": {
      "gap": { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap between slider and value display (12px)" }
    }
  },
  "radius": {
    "slider": {
      "track": { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Slider track radius" },
      "thumb": { "$type": "dimension", "$value": "{radius.component.full}", "$description": "Slider thumb radius" }
    }
  }
}
