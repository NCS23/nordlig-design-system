{
  "color": {
    "$description": "Level 4: Command component tokens",
    "command": {
      "bg":                { "$type": "color", "$value": "{color.bg.paper}", "$description": "Command palette background" },
      "border":            { "$type": "color", "$value": "{color.border.muted}", "$description": "Command palette border" },
      "input-text":        { "$type": "color", "$value": "{color.text.base}", "$description": "Command input text" },
      "input-placeholder": { "$type": "color", "$value": "{color.text.disabled}", "$description": "Command input placeholder" },
      "item-text":         { "$type": "color", "$value": "{color.text.base}", "$description": "Command item text" },
      "item-hover-bg":     { "$type": "color", "$value": "{color.bg.surface}", "$description": "Command item hover background" },
      "group-heading":     { "$type": "color", "$value": "{color.text.muted}", "$description": "Command group heading text" },
      "separator":         { "$type": "color", "$value": "{color.border.muted}", "$description": "Command separator color" },
      "empty-text":        { "$type": "color", "$value": "{color.text.muted}", "$description": "Command empty state text" }
    }
  },
  "shadow": {
    "command": { "$type": "shadow", "$value": "{shadow.elevation.overlay}", "$description": "Command palette shadow" }
  },
  "radius": {
    "command": { "$type": "dimension", "$value": "{radius.component.lg}", "$description": "Command palette border radius" }
  },
  "spacing": {
    "command": {
      "padding":         { "$type": "dimension", "$value": "{spacing.component.padding.sm}", "$description": "Command item padding" },
      "input-px":        { "$type": "dimension", "$value": "{spacing.component.padding.sm}", "$description": "12px input wrapper horizontal padding" },
      "list-padding":    { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "4px list inner padding" },
      "empty-py":        { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "24px empty state vertical padding" },
      "group-heading-py":{ "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "6px group heading vertical padding" },
      "item-px":         { "$type": "dimension", "$value": "{spacing.component.padding.xs}", "$description": "8px item horizontal padding" },
      "item-py":         { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "6px item vertical padding" },
      "separator-my":    { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "4px separator vertical margin" }
    }
  },
  "font": {
    "command": {
      "input-size":    { "$type": "dimension",   "$value": "{font.component.size.sm}",       "$description": "Input text size (14px)" },
      "item-size":     { "$type": "dimension",   "$value": "{font.component.size.sm}",       "$description": "Item text size (14px)" },
      "heading-size":  { "$type": "dimension",   "$value": "{font.component.size.xs}",       "$description": "Group heading size (12px)" },
      "heading-weight":{ "$type": "fontWeight",   "$value": "{font.component.weight.medium}",  "$description": "Group heading weight" },
      "shortcut-size": { "$type": "dimension",   "$value": "{font.component.size.xs}",       "$description": "Shortcut text size (12px)" }
    }
  }
}
