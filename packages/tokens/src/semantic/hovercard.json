{
  "color": {
    "$description": "Level 4: HoverCard component tokens",
    "hovercard": {
      "bg":     { "$type": "color", "$value": "{color.bg.elevated}", "$description": "HoverCard background" },
      "border": { "$type": "color", "$value": "{color.border.muted}", "$description": "HoverCard border" }
    }
  },
  "font": {
    "hovercard": {
      "content-size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "HoverCard content font size" }
    }
  },
  "shadow": {
    "hovercard": { "$type": "shadow", "$value": "{shadow.elevation.floating}", "$description": "HoverCard shadow" }
  },
  "radius": {
    "hovercard": { "$type": "dimension", "$value": "{radius.component.lg}", "$description": "HoverCard border radius" }
  },
  "spacing": {
    "hovercard": {
      "padding": { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "HoverCard content padding" }
    }
  }
}
