{
  "color": {
    "$description": "Level 4: Banner component tokens",
    "banner": {
      "info-bg":        { "$type": "color", "$value": "{color.bg.info}",      "$description": "Info background" },
      "info-text":      { "$type": "color", "$value": "{color.text.info}",    "$description": "Info text" },
      "info-border":    { "$type": "color", "$value": "{color.border.info}",  "$description": "Info border" },
      "success-bg":     { "$type": "color", "$value": "{color.bg.success}",     "$description": "Success background" },
      "success-text":   { "$type": "color", "$value": "{color.text.success}",   "$description": "Success text" },
      "success-border": { "$type": "color", "$value": "{color.border.success}", "$description": "Success border" },
      "warning-bg":     { "$type": "color", "$value": "{color.bg.warning}",     "$description": "Warning background" },
      "warning-text":   { "$type": "color", "$value": "{color.text.warning}",   "$description": "Warning text" },
      "warning-border": { "$type": "color", "$value": "{color.border.warning}", "$description": "Warning border" },
      "error-bg":       { "$type": "color", "$value": "{color.bg.error}",       "$description": "Error background" },
      "error-text":     { "$type": "color", "$value": "{color.text.error}",     "$description": "Error text" },
      "error-border":   { "$type": "color", "$value": "{color.border.error}",   "$description": "Error border" },
      "dismiss":        { "$type": "color", "$value": "{color.text.muted}",     "$description": "Dismiss icon color" }
    }
  },
  "font": {
    "banner": {
      "size": { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Banner content font size (text-sm)" }
    }
  },
  "radius": {
    "banner": {
      "dismiss": { "$type": "dimension", "$value": "{radius.component.sm}", "$description": "Dismiss button border radius (rounded-sm)" }
    }
  },
  "spacing": {
    "banner": {
      "padding-x": { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "Horizontal padding" },
      "padding-y": { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "Vertical padding" },
      "gap":             { "$type": "dimension", "$value": "{spacing.component.gap.md}",     "$description": "Gap between elements" },
      "dismiss-padding": { "$type": "dimension", "$value": "{spacing.component.gap.xs}",   "$description": "4px dismiss button padding" }
    }
  }
}
