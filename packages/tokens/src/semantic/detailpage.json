{
  "spacing": {
    "$description": "Level 4: DetailPage template tokens",
    "detailpage": {
      "header-gap":  { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap between header elements" },
      "section-gap": { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Gap between major sections" },
      "sidebar-gap": { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Gap between content and sidebar" },
      "content-gap": { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap within content body" }
    }
  },
  "sizing": {
    "detailpage": {
      "sidebar-width": { "$type": "dimension", "$value": "280px", "$description": "Sidebar width on desktop" }
    }
  },
  "font": {
    "detailpage": {
      "title-size":   { "$type": "dimension", "$value": "{font.heading.size.md}", "$description": "Page title font size (20px)" },
      "title-weight": { "$type": "dimension", "$value": "{font.component.weight.semibold}", "$description": "Page title font weight" }
    }
  }
}
