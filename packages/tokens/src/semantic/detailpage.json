{
  "spacing": {
    "$description": "Level 4: DetailPage template tokens",
    "detailpage": {
      "header-gap":  { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Gap between header elements (16px)" },
      "section-gap": { "$type": "dimension", "$value": "{spacing.component.gap.xl}", "$description": "Gap between major sections (32px)" },
      "sidebar-gap": { "$type": "dimension", "$value": "{spacing.layout.gutter}", "$description": "Gap between content and sidebar (24px)" },
      "content-gap": { "$type": "dimension", "$value": "{spacing.layout.gutter}", "$description": "Gap between cards in content (24px)" }
    }
  },
  "sizing": {
    "detailpage": {
      "sidebar-width": { "$type": "dimension", "$value": "280px", "$description": "Sidebar width on desktop" }
    }
  }
}
