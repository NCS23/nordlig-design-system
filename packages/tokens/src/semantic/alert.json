{
  "color": {
    "$description": "Level 4: Alert component tokens",
    "alert": {
      "title":          { "$type": "color", "$value": "{color.text.base}", "$description": "Alert title text (fallback)" },
      "description":    { "$type": "color", "$value": "{color.text.base}", "$description": "Alert description text (fallback)" },
      "info-bg":        { "$type": "color", "$value": "{color.bg.info-subtle}", "$description": "Info variant background" },
      "info-border":    { "$type": "color", "$value": "{color.border.info}", "$description": "Info left accent border" },
      "info-icon":      { "$type": "color", "$value": "{color.text.info}", "$description": "Info icon color" },
      "info-title":     { "$type": "color", "$value": "{color.text.info-strong}", "$description": "Info title text — Blue 800" },
      "info-description": { "$type": "color", "$value": "{color.text.info-strong}", "$description": "Info description text — Blue 800" },
      "success-bg":     { "$type": "color", "$value": "{color.bg.success-subtle}", "$description": "Success variant background" },
      "success-border": { "$type": "color", "$value": "{color.border.success}", "$description": "Success left accent border" },
      "success-icon":   { "$type": "color", "$value": "{color.text.success}", "$description": "Success icon color" },
      "success-title":  { "$type": "color", "$value": "{color.text.success-strong}", "$description": "Success title text — Emerald 800" },
      "success-description": { "$type": "color", "$value": "{color.text.success-strong}", "$description": "Success description text — Emerald 800" },
      "warning-bg":     { "$type": "color", "$value": "{color.bg.warning-subtle}", "$description": "Warning variant background" },
      "warning-border": { "$type": "color", "$value": "{color.border.warning}", "$description": "Warning left accent border" },
      "warning-icon":   { "$type": "color", "$value": "{color.text.warning}", "$description": "Warning icon color" },
      "warning-title":  { "$type": "color", "$value": "{color.text.warning-strong}", "$description": "Warning title text — Amber 800" },
      "warning-description": { "$type": "color", "$value": "{color.text.warning-strong}", "$description": "Warning description text — Amber 800" },
      "error-bg":       { "$type": "color", "$value": "{color.bg.error-subtle}", "$description": "Error variant background" },
      "error-border":   { "$type": "color", "$value": "{color.border.error}", "$description": "Error left accent border" },
      "error-icon":     { "$type": "color", "$value": "{color.text.error}", "$description": "Error icon color" },
      "error-title":    { "$type": "color", "$value": "{color.text.error-strong}", "$description": "Error title text — Red 800" },
      "error-description": { "$type": "color", "$value": "{color.text.error-strong}", "$description": "Error description text — Red 800" }
    }
  },
  "radius": {
    "alert": { "$type": "dimension", "$value": "{radius.component.md}", "$description": "6px rounded corners" }
  },
  "spacing": {
    "$description": "Level 4: Alert spacing tokens",
    "alert": {
      "padding":       { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "Alert padding all sides (16px)" },
      "gap":           { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Gap between icon and content (12px)" },
      "icon-mt":       { "$type": "dimension", "$value": "{spacing.component.gap.2xs}", "$description": "Icon top margin for vertical alignment (2px)" },
      "close-padding": { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Close button padding (4px)" },
      "title-mb":      { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Title bottom margin (4px)" }
    }
  },
  "sizing": {
    "$description": "Level 4: Alert sizing tokens",
    "alert": {
      "border-width":    { "$type": "dimension", "$value": "{sizing.component.track.sm}", "$description": "Left accent border width (4px)" },
      "font-size":       { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Text font size (14px)" },
      "title-weight":    { "$type": "number", "$value": "{font.component.weight.semibold}", "$description": "Title font weight (600)" }
    }
  }
}
