{
  "color": {
    "$description": "Level 4: NumberInput component tokens",
    "numberinput": {
      "bg": {
        "$type": "color",
        "$value": "{color.base.white}",
        "$description": "Pure white for contrast on paper surfaces"
      },
      "bg-disabled": {
        "$type": "color",
        "$value": "{color.bg.surface}",
        "$description": "Disabled background"
      },
      "text": {
        "$type": "color",
        "$value": "{color.text.base}",
        "$description": "Input value text"
      },
      "border": {
        "$type": "color",
        "$value": "{color.border.default}",
        "$description": "Default border"
      },
      "border-hover": {
        "$type": "color",
        "$value": "{color.border.strong}",
        "$description": "Hover border"
      },
      "border-focus": {
        "$type": "color",
        "$value": "{color.border.focus}",
        "$description": "Focus ring color"
      },
      "border-error": {
        "$type": "color",
        "$value": "{color.border.error}",
        "$description": "Error border"
      },
      "stepper-text": {
        "$type": "color",
        "$value": "{color.text.muted}",
        "$description": "Stepper button icon color"
      },
      "stepper-text-hover": {
        "$type": "color",
        "$value": "{color.text.base}",
        "$description": "Stepper button icon hover color"
      },
      "stepper-bg-hover": {
        "$type": "color",
        "$value": "{color.bg.surface}",
        "$description": "Stepper button hover background"
      }
    }
  },
  "font": {
    "numberinput": {
      "weight": { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Input value font weight (500)" }
    }
  },
  "sizing": {
    "numberinput": {
      "border-width": { "$type": "dimension", "$value": "{sizing.component.border-width.default}", "$description": "NumberInput border width (1px)" }
    }
  },
  "spacing": {
    "numberinput": {
      "stepper-px": { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "8px stepper button horizontal padding" }
    }
  },
  "radius": {
    "numberinput": {
      "$type": "dimension",
      "$value": "{radius.component.md}",
      "$description": "NumberInput border radius"
    }
  }
}
