{
  "font": {
    "$description": "Level 4: Heading component tokens",
    "heading": {
      "h1": {
        "size":        { "$type": "dimension", "$value": "{font.heading.size.2xl}", "$description": "h1 font size (2.25rem / text-4xl)" },
        "weight":      { "$type": "fontWeight", "$value": "{font.component.weight.semibold}", "$description": "h1 font weight (600)" },
        "line-height": { "$type": "dimension", "$value": "{font.heading.line-height.2xl}", "$description": "h1 line-height (45px / 1.25x)" }
      },
      "h2": {
        "size":        { "$type": "dimension", "$value": "{font.heading.size.xl}", "$description": "h2 font size (1.875rem / text-3xl)" },
        "weight":      { "$type": "fontWeight", "$value": "{font.component.weight.semibold}", "$description": "h2 font weight (600)" },
        "line-height": { "$type": "dimension", "$value": "{font.heading.line-height.xl}", "$description": "h2 line-height (36px / 1.2x)" }
      },
      "h3": {
        "size":        { "$type": "dimension", "$value": "{font.heading.size.lg}", "$description": "h3 font size (1.5rem / text-2xl)" },
        "weight":      { "$type": "fontWeight", "$value": "{font.component.weight.semibold}", "$description": "h3 font weight (600)" },
        "line-height": { "$type": "dimension", "$value": "{font.heading.line-height.lg}", "$description": "h3 line-height (30px / 1.25x)" }
      },
      "h4": {
        "size":        { "$type": "dimension", "$value": "{font.heading.size.md}", "$description": "h4 font size (1.25rem / text-xl)" },
        "weight":      { "$type": "fontWeight", "$value": "{font.component.weight.semibold}", "$description": "h4 font weight (600)" },
        "line-height": { "$type": "dimension", "$value": "{font.heading.line-height.md}", "$description": "h4 line-height (27px / 1.35x)" }
      },
      "h5": {
        "size":        { "$type": "dimension", "$value": "{font.heading.size.sm}", "$description": "h5 font size (1.125rem / text-lg)" },
        "weight":      { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "h5 font weight (500)" },
        "line-height": { "$type": "dimension", "$value": "{font.heading.line-height.sm}", "$description": "h5 line-height (24px / 1.33x)" }
      },
      "h6": {
        "size":        { "$type": "dimension", "$value": "{font.heading.size.xs}", "$description": "h6 font size (1rem / text-base)" },
        "weight":      { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "h6 font weight (500)" },
        "line-height": { "$type": "dimension", "$value": "{font.heading.line-height.xs}", "$description": "h6 line-height (24px / 1.5x)" }
      }
    }
  }
}
