{
  "color": {
    "$description": "Level 4: Switch/Toggle component tokens",
    "switch": {
      "track-bg":           { "$type": "color", "$value": "{color.border.default}", "$description": "Unchecked track (gray-300)" },
      "track-bg-checked":   { "$type": "color", "$value": "{color.interactive.primary}", "$description": "Checked track (sky blue)" },
      "thumb-bg":           { "$type": "color", "$value": "{color.bg.paper}", "$description": "White thumb" },
      "focus-ring":         { "$type": "color", "$value": "{color.border.focus}", "$description": "Sky blue focus ring" },
      "disabled-track-bg":  { "$type": "color", "$value": "{color.bg.surface}", "$description": "Disabled track" },
      "label":              { "$type": "color", "$value": "{color.text.base}", "$description": "Label text color" },
      "description":        { "$type": "color", "$value": "{color.text.muted}", "$description": "Description text color" }
    }
  },
  "sizing": {
    "$description": "Level 4: Switch size tokens — References Level 3 only",
    "switch": {
      "track-height": { "$type": "dimension", "$value": "{sizing.component.icon.md}", "$description": "Switch track height (24px = h-6)" },
      "track-width":  { "$type": "dimension", "$value": "{sizing.component.height.lg}", "$description": "Switch track width (44px = w-11)" },
      "thumb-size":   { "$type": "dimension", "$value": "{sizing.component.icon.sm}", "$description": "Switch thumb size (16px via L3) — TODO: Need L3 token for 20px (h-5 w-5). Currently using icon.sm=16px as closest available" }
    }
  },
  "shadow": {
    "switch": {
      "thumb": { "$type": "shadow", "$value": "{shadow.elevation.low}", "$description": "Thumb shadow" }
    }
  }
}
