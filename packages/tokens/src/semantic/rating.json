{
  "color": {
    "$description": "Level 4: Rating component tokens",
    "rtg": {
      "filled": { "$type": "color", "$value": "{color.text.warning}",     "$description": "Filled star (gold/amber)" },
      "empty":  { "$type": "color", "$value": "{color.text.disabled}",    "$description": "Empty star" },
      "hover":  { "$type": "color", "$value": "{color.border.warning}",   "$description": "Hover color" }
    }
  },
  "spacing": {
    "rtg": {
      "gap": { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between stars" }
    }
  },
  "radius": {
    "rtg": {
      "focus": { "$type": "dimension", "$value": "{radius.component.sm}", "$description": "4px focus outline radius" }
    }
  },
  "sizing": {
    "rtg": {
      "sm": { "$type": "dimension", "$value": "{sizing.component.icon.sm}", "$description": "Star size sm" },
      "md": { "$type": "dimension", "$value": "{sizing.component.icon.md}", "$description": "Star size md" },
      "lg": { "$type": "dimension", "$value": "{sizing.component.icon.lg}", "$description": "Star size lg" }
    }
  }
}
