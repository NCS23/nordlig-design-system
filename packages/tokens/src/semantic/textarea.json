{
  "color": {
    "$description": "Level 4: Textarea component tokens – extends Input styling",
    "textarea": {
      "counter-text":      { "$type": "color", "$value": "{color.text.muted}", "$description": "Character counter default" },
      "counter-text-over": { "$type": "color", "$value": "{color.text.error}", "$description": "Counter when over limit" }
    }
  },
  "sizing": {
    "$description": "Level 4: Textarea sizing",
    "textarea": {
      "min-height": { "$type": "dimension", "$value": "100px", "$description": "Default minimum height" },
      "max-height":  { "$type": "dimension", "$value": "400px", "$description": "Auto-resize maximum" }
    }
  },
  "spacing": {
    "textarea": {
      "padding-y-sm": { "$type": "dimension", "$value": "{sizing.component.padding-y.md}", "$description": "8px – sm size vertical padding" },
      "padding-y-md": { "$type": "dimension", "$value": "{sizing.component.padding-y.lg}", "$description": "10px – md size vertical padding" },
      "padding-y-lg": { "$type": "dimension", "$value": "{sizing.component.padding-y.xl}", "$description": "12px – lg size vertical padding" },
      "field-gap":    { "$type": "dimension", "$value": "{sizing.component.gap.sm}", "$description": "Gap between label, textarea, and hint (6px)" },
      "footer-gap":   { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between hint and character count (8px)" }
    }
  },
  "font": {
    "textarea": {
      "label-size":   { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Label font size (text-sm equivalent)" },
      "label-weight": { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Label font weight (font-medium)" },
      "hint-size":    { "$type": "dimension", "$value": "{font.component.size.xs}", "$description": "Helper/error text font size (text-xs equivalent)" },
      "counter-size": { "$type": "dimension", "$value": "{font.component.size.xs}", "$description": "Character counter font size (text-xs equivalent)" },
      "counter-weight": { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "Counter over-limit font weight (font-medium)" }
    }
  }
}
