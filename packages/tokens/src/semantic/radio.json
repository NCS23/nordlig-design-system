{
  "color": {
    "$description": "Level 4: RadioGroup component tokens",
    "radio": {
      "bg":              { "$type": "color", "$value": "{color.bg.paper}", "$description": "Unchecked background (white)" },
      "border":          { "$type": "color", "$value": "{color.border.default}", "$description": "Unchecked border" },
      "border-hover":    { "$type": "color", "$value": "{color.border.strong}", "$description": "Hover border" },
      "selected-border": { "$type": "color", "$value": "{color.interactive.primary}", "$description": "Sky blue selected border" },
      "selected-dot":    { "$type": "color", "$value": "{color.interactive.primary}", "$description": "Sky blue inner dot" },
      "focus-ring":      { "$type": "color", "$value": "{color.border.focus}", "$description": "Sky blue focus ring" },
      "disabled-bg":     { "$type": "color", "$value": "{color.bg.surface}", "$description": "Disabled background" },
      "item-hover-bg":   { "$type": "color", "$value": "{color.bg.surface}", "$description": "Row hover background" },
      "label":           { "$type": "color", "$value": "{color.text.base}", "$description": "Label text color" },
      "description":     { "$type": "color", "$value": "{color.text.muted}", "$description": "Description text color" }
    }
  },
  "radius": {
    "radio": {
      "item": { "$type": "dimension", "$value": "{radius.component.md}", "$description": "6px item row rounding" }
    }
  }
}
