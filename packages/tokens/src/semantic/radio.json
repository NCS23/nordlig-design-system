{
  "color": {
    "$description": "Level 4: RadioGroup component tokens",
    "radio": {
      "bg":              { "$type": "color", "$value": "{color.bg.paper}", "$description": "Unchecked background (white)" },
      "border":          { "$type": "color", "$value": "{color.border.default}", "$description": "Unchecked border" },
      "border-hover":    { "$type": "color", "$value": "{color.border.strong}", "$description": "Hover border" },
      "selected-border": { "$type": "color", "$value": "{color.interactive.primary}", "$description": "Sky blue selected border" },
      "selected-dot":    { "$type": "color", "$value": "{color.interactive.primary}", "$description": "Sky blue inner dot" },
      "focus-ring":      { "$type": "color", "$value": "{color.border.focus}", "$description": "Sky blue focus ring" },
      "disabled-bg":     { "$type": "color", "$value": "{color.bg.surface}", "$description": "Disabled background" },
      "item-hover-bg":   { "$type": "color", "$value": "{color.bg.surface}", "$description": "Row hover background" },
      "label":           { "$type": "color", "$value": "{color.text.base}", "$description": "Label text color" },
      "description":     { "$type": "color", "$value": "{color.text.muted}", "$description": "Description text color" }
    }
  },
  "font": {
    "radio": {
      "label-size":        { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "14px label text" },
      "label-weight":      { "$type": "fontWeight", "$value": "{font.component.weight.medium}", "$description": "500 label weight" },
      "description-size":  { "$type": "dimension", "$value": "{font.component.size.xs}", "$description": "12px description text" }
    }
  },
  "sizing": {
    "$description": "Level 4: Radio size tokens — References Level 3 only",
    "radio": {
      "button-size": { "$type": "dimension", "$value": "{sizing.component.icon.sm}", "$description": "Radio button outer size (16px via L3) — TODO: Need L3 token for 20px (h-5 w-5). Currently using icon.sm=16px as closest available" },
      "dot-size":    { "$type": "dimension", "$value": "{sizing.component.track.lg}", "$description": "Radio inner dot size (12px)" }
    }
  },
  "radius": {
    "radio": {
      "item": { "$type": "dimension", "$value": "{radius.component.md}", "$description": "6px item row rounding" }
    }
  },
  "spacing": {
    "radio": {
      "group-gap-v":  { "$type": "dimension", "$value": "{spacing.component.gap.md}", "$description": "Vertical gap between radio items (12px)" },
      "group-gap-h":  { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "Horizontal gap between radio items (16px)" },
      "item-gap":     { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "Gap between radio and label (8px)" },
      "content-gap":  { "$type": "dimension", "$value": "{spacing.component.gap.2xs}", "$description": "Gap between label and description (2px)" }
    }
  }
}
