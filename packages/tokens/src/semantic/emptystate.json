{
  "color": {
    "$description": "Level 4: EmptyState component tokens",
    "emptystate": {
      "icon":         { "$type": "color", "$value": "{color.text.muted}", "$description": "Default icon color (muted)" },
      "icon-error":   { "$type": "color", "$value": "{color.text.error}", "$description": "Error variant icon color" },
      "icon-success": { "$type": "color", "$value": "{color.text.success}", "$description": "Success variant icon color" },
      "title":        { "$type": "color", "$value": "{color.text.base}", "$description": "Title text color" },
      "description":  { "$type": "color", "$value": "{color.text.muted}", "$description": "Description text color (muted)" }
    }
  },
  "font": {
    "emptystate": {
      "title-size":   { "$type": "dimension", "$value": "{font.component.size.lg}", "$description": "Title font size (text-lg)" },
      "title-weight": { "$type": "dimension", "$value": "{font.component.weight.semibold}", "$description": "Title font weight (semibold)" },
      "desc-size":    { "$type": "dimension", "$value": "{font.component.size.sm}", "$description": "Description font size (text-sm)" }
    }
  },
  "spacing": {
    "emptystate": {
      "padding-y":  { "$type": "dimension", "$value": "48px", "$description": "48px vertical padding" },
      "padding-x":  { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px horizontal padding" },
      "icon-mb":    { "$type": "dimension", "$value": "{spacing.component.gap.lg}", "$description": "16px below icon" },
      "title-mb":   { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "8px below title" },
      "desc-mb":    { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "24px below description" }
    }
  }
}
