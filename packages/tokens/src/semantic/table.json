{
  "color": {
    "$description": "Level 4: Table component tokens",
    "table": {
      "header-bg":   { "$type": "color", "$value": "{color.bg.surface}" },
      "header-text": { "$type": "color", "$value": "{color.text.base}" },
      "border":      { "$type": "color", "$value": "{color.border.muted}" },
      "row-stripe":  { "$type": "color", "$value": "{color.neutral.1.50}" },
      "row-hover":   { "$type": "color", "$value": "{color.neutral.1.100}" }
    }
  },
  "spacing": {
    "$description": "Level 4: Table spacing – generous for Scandinavian whitespace feel",
    "table": {
      "cell-x-compact":  { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px – airy even at compact" },
      "cell-y-compact":  { "$type": "dimension", "$value": "{spacing.component.padding.sm}", "$description": "12px – body vertical compact" },
      "cell-x-normal":   { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "24px – generous horizontal" },
      "cell-y-normal":   { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px – body vertical normal" },
      "cell-x-spacious": { "$type": "dimension", "$value": "{spacing.component.padding.xl}", "$description": "32px – luxurious horizontal" },
      "cell-y-spacious": { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "24px – body vertical spacious" },
      "head-y-compact":  { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "16px – header extra room compact" },
      "head-y-normal":   { "$type": "dimension", "$value": "{spacing.component.padding.lg}", "$description": "24px – header extra room normal" },
      "head-y-spacious": { "$type": "dimension", "$value": "{spacing.component.padding.xl}", "$description": "32px – header extra room spacious" }
    }
  }
}
