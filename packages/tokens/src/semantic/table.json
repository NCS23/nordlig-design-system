{
  "color": {
    "$description": "Level 4: Table component tokens",
    "table": {
      "header-bg":   { "$type": "color", "$value": "{color.bg.surface}" },
      "header-text": { "$type": "color", "$value": "{color.text.base}" },
      "border":      { "$type": "color", "$value": "{color.border.muted}" },
      "row-stripe":  { "$type": "color", "$value": "{color.neutral.1.50}" },
      "row-hover":   { "$type": "color", "$value": "{color.neutral.1.100}" }
    }
  },
  "spacing": {
    "$description": "Level 4: Table cell padding per density",
    "table": {
      "cell-x-compact":  { "$type": "dimension", "$value": "{sizing.component.padding-x.sm}" },
      "cell-y-compact":  { "$type": "dimension", "$value": "{sizing.component.padding-y.sm}" },
      "cell-x-normal":   { "$type": "dimension", "$value": "{sizing.component.padding-x.md}" },
      "cell-y-normal":   { "$type": "dimension", "$value": "{sizing.component.padding-y.md}" },
      "cell-x-spacious": { "$type": "dimension", "$value": "{sizing.component.padding-x.md}" },
      "cell-y-spacious": { "$type": "dimension", "$value": "{sizing.component.padding-y.lg}" }
    }
  }
}
