{
  "color": {
    "$description": "Level 4: Menubar component tokens (dropdown content reuses dropdown.json tokens)",
    "menubar": {
      "bg":                { "$type": "color", "$value": "{color.bg.elevated}", "$description": "Menubar background" },
      "border":            { "$type": "color", "$value": "{color.border.muted}", "$description": "Menubar border" },
      "trigger-text":      { "$type": "color", "$value": "{color.text.base}", "$description": "Trigger text" },
      "trigger-hover-bg":  { "$type": "color", "$value": "{color.bg.surface}", "$description": "Trigger hover background" },
      "trigger-active-bg": { "$type": "color", "$value": "{color.bg.surface}", "$description": "Trigger active/open background" }
    }
  },
  "radius": {
    "menubar": {
      "bar":  { "$type": "dimension", "$value": "{radius.component.md}", "$description": "Menubar container radius" },
      "item": { "$type": "dimension", "$value": "{radius.component.sm}", "$description": "Trigger item radius" }
    }
  },
  "spacing": {
    "menubar": {
      "padding":           { "$type": "dimension", "$value": "{spacing.component.padding.xs}", "$description": "Menubar inner padding" },
      "trigger-padding-x": { "$type": "dimension", "$value": "{spacing.component.padding.md}", "$description": "Trigger horizontal padding" },
      "trigger-padding-y": { "$type": "dimension", "$value": "{spacing.component.padding.xs}", "$description": "Trigger vertical padding" },
      "gap":               { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "Gap between menubar items (4px)" },
      "item-py":           { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "6px dropdown item vertical padding" },
      "separator-my":      { "$type": "dimension", "$value": "{spacing.component.gap.xs}", "$description": "4px separator vertical margin" },
      "indicator-left":    { "$type": "dimension", "$value": "{spacing.component.gap.sm}", "$description": "8px checkbox/radio indicator left offset" }
    }
  },
  "sizing": {
    "menubar": {
      "item-icon": { "$type": "dimension", "$value": "{sizing.component.icon.sm}", "$description": "16px item icon size" }
    }
  },
  "font": {
    "menubar": {
      "trigger-size":   { "$type": "dimension",   "$value": "{font.component.size.sm}",       "$description": "Trigger text size (14px)" },
      "trigger-weight": { "$type": "fontWeight",   "$value": "{font.component.weight.medium}",  "$description": "Trigger text weight" },
      "item-size":      { "$type": "dimension",   "$value": "{font.component.size.sm}",       "$description": "Item text size (14px)" },
      "label-size":     { "$type": "dimension",   "$value": "{font.component.size.xs}",       "$description": "Label text size (12px)" },
      "label-weight":   { "$type": "fontWeight",   "$value": "{font.component.weight.semibold}", "$description": "Label text weight" },
      "shortcut-size":  { "$type": "dimension",   "$value": "{font.component.size.xs}",       "$description": "Shortcut text size (12px)" }
    }
  }
}
