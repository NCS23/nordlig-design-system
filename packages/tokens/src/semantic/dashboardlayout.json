{
  "color": {
    "$description": "Level 4: DashboardLayout template tokens",
    "dashboard": {
      "bg":         { "$type": "color", "$value": "{color.bg.paper}", "$description": "Page background" },
      "overlay-bg": { "$type": "color", "$value": "{color.bg.overlay}", "$description": "Mobile sidebar backdrop" }
    }
  },
  "sizing": {
    "$description": "Level 4: DashboardLayout sizing",
    "dashboard": {
      "sidebar-width":           { "$type": "dimension", "$value": "240px", "$description": "Sidebar expanded width" },
      "sidebar-collapsed-width": { "$type": "dimension", "$value": "64px", "$description": "Sidebar collapsed width" }
    }
  },
  "spacing": {
    "dashboard": {
      "content-p": { "$type": "dimension", "$value": "{spacing.component.padding.xl}", "$description": "Content area padding (32px)" }
    }
  }
}
