{
  "sizing": {
    "$description": "Level 3: Role sizing tokens — functional component dimensions",
    "component": {
      "height": {
        "sm": { "$type": "dimension", "$value": "{sizing.height.sm}" },
        "md": { "$type": "dimension", "$value": "{sizing.height.md}" },
        "lg": { "$type": "dimension", "$value": "{sizing.height.lg}" }
      },
      "padding-x": {
        "sm": { "$type": "dimension", "$value": "{sizing.padding-x.sm}" },
        "md": { "$type": "dimension", "$value": "{sizing.padding-x.md}" },
        "lg": { "$type": "dimension", "$value": "{sizing.padding-x.lg}" }
      },
      "padding-y": {
        "sm": { "$type": "dimension", "$value": "{sizing.padding-y.sm}" },
        "md": { "$type": "dimension", "$value": "{sizing.padding-y.md}" },
        "lg": { "$type": "dimension", "$value": "{sizing.padding-y.lg}" },
        "xl": { "$type": "dimension", "$value": "{sizing.padding-y.xl}" }
      },
      "gap": {
        "sm": { "$type": "dimension", "$value": "{sizing.gap.sm}" },
        "md": { "$type": "dimension", "$value": "{sizing.gap.md}" },
        "lg": { "$type": "dimension", "$value": "{sizing.gap.lg}" }
      },
      "icon": {
        "sm": { "$type": "dimension", "$value": "{spacing.md}" },
        "control": { "$type": "dimension", "$value": "{spacing.md-lg}", "$description": "20px — checkbox, switch thumb, slider thumb" },
        "md": { "$type": "dimension", "$value": "{spacing.lg}" },
        "lg": { "$type": "dimension", "$value": "{spacing.xl}" },
        "xl": { "$type": "dimension", "$value": "{spacing.2xl}" }
      },
      "track": {
        "sm": { "$type": "dimension", "$value": "{spacing.2xs}" },
        "md": { "$type": "dimension", "$value": "{spacing.xs}" },
        "lg": { "$type": "dimension", "$value": "{spacing.sm}" }
      }
    }
  }
}
