      "secondary-active": { "$type": "color", "$value": "{color.neutral.1.700}" },
      "hover-overlay":    { "$type": "color", "$value": "{color.neutral.1.200}", "$description": "Subtle hover feedback (replaces bg-black/5, bg-black/10)" }
    }
  }
