      "info-subtle":     { "$type": "color", "$value": "{color.accent.4.50}" },
      "info":            { "$type": "color", "$value": "{color.accent.4.100}" },
      "info-solid":      { "$type": "color", "$value": "{color.accent.4.500}" },
      "overlay": { "$type": "color", "$value": "{color.neutral.overlay}", "$description": "Modal/dialog backdrop" },
