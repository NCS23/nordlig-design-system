{
  "spacing": {
    "$description": "Level 2: Global semantic spacing sizes",
    "3xs": { "$type": "dimension", "$value": "{spacing.base.0-5}", "$description": "2px" },
    "2xs": { "$type": "dimension", "$value": "{spacing.base.1}" },
    "xs":  { "$type": "dimension", "$value": "{spacing.base.2}" },
    "sm":  { "$type": "dimension", "$value": "{spacing.base.3}" },
    "md":  { "$type": "dimension", "$value": "{spacing.base.4}" },
    "md-lg": { "$type": "dimension", "$value": "{spacing.base.5}", "$description": "20px — control element size (checkbox, switch thumb, slider thumb)" },
    "lg":  { "$type": "dimension", "$value": "{spacing.base.6}" },
    "xl":  { "$type": "dimension", "$value": "{spacing.base.8}" },
    "2xl": { "$type": "dimension", "$value": "{spacing.base.12}" },
    "3xl": { "$type": "dimension", "$value": "{spacing.base.16}" }
  }
}
